# ─────────────────────────────────────────────
# OneBrain — Local Development Environment
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Application
NODE_ENV=development

# API Server
API_PORT=3001
API_HOST=0.0.0.0

# Web App
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4002
NEXT_PUBLIC_DEMO_MODE=false

# OAuth Client IDs (frontend — leave empty to hide button)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# MCP Server
MCP_PORT=3002
ONEBRAIN_API_URL=http://localhost:3001
ONEBRAIN_API_KEY=

# Database
# Pool params: connection_limit (default: num_cpus*2+1), pool_timeout (seconds),
# statement_timeout (ms), connect_timeout (seconds). Production example:
# DATABASE_URL=postgresql://onebrain:pass@db:5432/onebrain?connection_limit=20&pool_timeout=10&statement_timeout=5000&connect_timeout=5
DATABASE_URL=postgresql://onebrain:onebrain@localhost:5432/onebrain
# Read replica (future — use with PgBouncer for read-heavy queries)
# DATABASE_READ_URL=postgresql://onebrain:onebrain@localhost:5433/onebrain

# Retention job (optional — disable to run as separate worker)
# DISABLE_RETENTION_JOB=true

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
# Magic link expiry in milliseconds (default: 900000 = 15 minutes)
MAGIC_LINK_EXPIRY_MS=900000

# Mail (Resend — get your API key at https://resend.com)
RESEND_API_KEY=
MAIL_FROM=OneBrain <noreply@onebrain.rocks>

# CORS
CORS_ORIGIN=http://localhost:3000

# Public URL (used in OpenAPI specs and system prompts)
API_PUBLIC_URL=http://localhost:3001

# Retention job interval in hours (default: 6)
RETENTION_INTERVAL_HOURS=6

# Audit log retention in days (default: 365)
AUDIT_LOG_RETENTION_DAYS=365

# OAuth (optional — leave empty to disable provider)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# TOTP Encryption (optional — leave empty to store secrets in plaintext)
# 32-byte hex key (64 characters). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=

# Per-tenant memory encryption key (optional, recommended for production)
# 32-byte hex key (64 characters). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MEMORY_ENCRYPTION_KEY=

# Agent Provisioning (optional — leave empty to disable the endpoint)
# Shared secret for automated agent account creation (POST /v1/agent-provision)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_PROVISIONING_KEY=

# Stripe (optional — leave empty for self-hosted mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# OpenAI (optional — required for DeepRecall semantic search / embeddings)
OPENAI_API_KEY=
# OpenRouter (preferred over OPENAI_API_KEY — routes to cheapest embedding model)
OPENROUTER_API_KEY=
# Embedding model (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# Memory TTL in days (default: 365, set 0 to disable expiration)
MEMORY_TTL_DAYS=365

# Logging
LOG_LEVEL=info
