{
  "name": "@onebrain/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.0.0",
    "@onebrain/db": "workspace:*",
    "@onebrain/i18n": "workspace:*",
    "@onebrain/schemas": "workspace:*",
    "@onebrain/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.1",
    "fastify": "^5.8.3",
    "ioredis": "^5.10.1",
    "jose": "^6.0.0",
    "resend": "^6.9.4",
    "stripe": "^22.0.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "pdf-parse": "^1.1.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
