# ─────────────────────────────────────────────
# GLOBAL Region Environment
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=onebrain_global
POSTGRES_USER=onebrain
POSTGRES_PASSWORD=CHANGE_ME_global_db_password

# Redis
REDIS_PASSWORD=CHANGE_ME_global_redis_password

# API
API_PORT=3001
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
MAGIC_LINK_EXPIRY=15m
CORS_ORIGIN=https://your-domain.com

# Mail (Resend)
RESEND_API_KEY=
MAIL_FROM=OneBrain <noreply@onebrain.rocks>

# MCP Server
MCP_API_KEY=
