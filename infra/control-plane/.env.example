# ─────────────────────────────────────────────
# Control Plane Environment
# ─────────────────────────────────────────────

# Domain for Caddy auto-HTTPS (use localhost for local dev)
DOMAIN=localhost

# Basic auth — protects all routes except /api/eu/v1/connect/* and /api/eu/health
# Generate hash: caddy hash-password --plaintext 'your-password'
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=

# API hosts (internal Docker network names)
API_EU_HOST=api-eu
API_GLOBAL_HOST=api-global

# Public API URL for the web frontend (baked into Next.js at build time)
API_URL=https://onebrain.rocks/api/eu
