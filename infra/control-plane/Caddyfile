{$DOMAIN:localhost} {
    # ── API routes bypass basic auth (Fastify handles its own auth) ──
    handle_path /api/eu/* {
        reverse_proxy {$API_EU_HOST:api-eu}:3001
    }

    handle_path /api/global/* {
        reverse_proxy {$API_GLOBAL_HOST:api-global}:3001
    }

    # ── Web UI (public) ──
    handle {
        reverse_proxy web:3000
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "0"
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        -Server
    }

    # Compression
    encode gzip zstd

    # Logging
    log {
        output stdout
        format console
    }
}
