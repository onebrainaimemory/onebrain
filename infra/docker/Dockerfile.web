# ─────────────────────────────────────────────
# OneBrain Web — Multi-stage Docker build
# ─────────────────────────────────────────────

# Stage 1: Install dependencies
FROM node:22-alpine AS deps
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/i18n/package.json packages/i18n/
COPY apps/web/package.json apps/web/
RUN pnpm install --frozen-lockfile --prod=false

# Stage 2: Build
FROM node:22-alpine AS build
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY --from=deps /app/packages/i18n/node_modules ./packages/i18n/node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
ARG NEXT_PUBLIC_API_URL=http://localhost:3001
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
RUN pnpm --filter @onebrain/shared run build && \
    pnpm --filter @onebrain/i18n run build && \
    pnpm --filter @onebrain/web run build

# Stage 3: Production
FROM node:22-alpine AS runner
RUN addgroup --system --gid 1001 onebrain && \
    adduser --system --uid 1001 onebrain
WORKDIR /app

COPY --from=build --chown=onebrain:onebrain /app/apps/web/.next/standalone ./
COPY --from=build --chown=onebrain:onebrain /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=onebrain:onebrain /app/apps/web/public ./apps/web/public

USER onebrain
EXPOSE 3000
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
ENV NEXT_TELEMETRY_DISABLED=1

CMD ["node", "apps/web/server.js"]
