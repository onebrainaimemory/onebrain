# ─────────────────────────────────────────────
# OneBrain MCP Server — Multi-stage Docker build
# ─────────────────────────────────────────────

# Stage 1: Install dependencies
FROM node:22-alpine AS deps
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/shared/package.json packages/shared/
COPY apps/mcp/package.json apps/mcp/
RUN pnpm install --frozen-lockfile --prod=false

# Stage 2: Build
FROM node:22-alpine AS build
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY --from=deps /app/apps/mcp/node_modules ./apps/mcp/node_modules
COPY . .
RUN pnpm --filter @onebrain/shared run build && \
    pnpm --filter @onebrain/mcp run build

# Stage 3: Production
FROM node:22-alpine AS runner
RUN addgroup --system --gid 1001 onebrain && \
    adduser --system --uid 1001 onebrain
WORKDIR /app

COPY --from=build --chown=onebrain:onebrain /app/apps/mcp/dist ./apps/mcp/dist
COPY --from=build --chown=onebrain:onebrain /app/apps/mcp/package.json ./apps/mcp/
COPY --from=build --chown=onebrain:onebrain /app/apps/mcp/node_modules ./apps/mcp/node_modules
COPY --from=build --chown=onebrain:onebrain /app/packages/shared/dist ./packages/shared/dist
COPY --from=build --chown=onebrain:onebrain /app/packages/shared/package.json ./packages/shared/
COPY --from=build --chown=onebrain:onebrain /app/node_modules ./node_modules
COPY --from=build --chown=onebrain:onebrain /app/package.json ./
COPY --from=build --chown=onebrain:onebrain /app/pnpm-workspace.yaml ./

USER onebrain
ENV NODE_ENV=production

CMD ["node", "apps/mcp/dist/index.js"]
